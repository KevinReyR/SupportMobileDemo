{
  "expo": {
    "name": "Support Colombia",
    "slug": "support-colombia-mobile",
    "scheme": "support-colombia",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/support-icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "co.supportcolombia.mobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Support Colombia necesita acceso a la cámara para tomar foto de la cédula del contratista."
      }
    },
    "android": {
      "package": "co.supportcolombia.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#F8FAFF",
        "foregroundImage": "./assets/support-icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/support-logo.png"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-dev-client",
      [
        "expo-camera",
        {
          "cameraPermission": "Support Colombia necesita acceso a la cámara para tomar foto de la cédula del contratista."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9a4d8403-c447-4115-bd81-2a9d49d469e9"
      }
    }
  }
}
